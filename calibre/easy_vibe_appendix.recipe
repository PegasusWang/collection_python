def get_local_links(urls):
    local = "http://localhost:4173/easy-vibe"
    ori = "https://datawhalechina.github.io/easy-vibe"
    res = []
    for o in urls:
        url = o["url"]
        url = url.replace(ori, local)
        new_url  = {
            "title": o["title"],
            "url": url
        }
        res.append(new_url)
    return res



def get_local_links(urls):
    local = "http://localhost:4173/easy-vibe"
    ori = "https://datawhalechina.github.io/easy-vibe"
    res = []
    for o in urls:
        url = o["url"]
        url = url.replace(ori, local)
        new_url  = {
            "title": o["title"],
            "url": url
        }
        res.append(new_url)
    return res
class Blog(BasicNewsRecipe):  # 继承 BasicNewsRecipe 类的新类名

    # ///////////////////
    # 设置电子书元数据
    # ///////////////////
    title = "easy_vibe_appendix"  # 电子书名
    description = u"easy vibe附录知识库"  # 电子书简介
    # cover_url = '' # 电子书封面
    # masthead_url = '' # 页头图片
    __author__ = "web"  # 作者
    language = "zh"  # 语言
    encoding = "utf-8"  # 编码

    # ///////////////////
    # 抓取页面内容设置
    # ///////////////////
    # keep_only_tags = [{ 'class': 'example' }] # 仅保留指定选择器包含的内容
    # no_stylesheets = True  # 去除 CSS 样式
    remove_javascript = True  # 去除 JavaScript 脚本
    auto_cleanup = True  # 自动清理 HTML 代码
    delay = 5  # 抓取页面间隔秒数
    max_articles_per_feed = 300  # 抓取文章数量
    timeout = 120.0
    simultaneous_downloads = 5  # 有时候多个同时下载会失败，修改小点或者单线程下载

    # 页面内容解析方法
    def parse_index(self):
        local_links = get_local_links(easy_vibe_appendix_links)
        print(local_links)
        ans = [(self.title, local_links)]
        return ans  # 返回可供 Calibre 转换的数据结构
