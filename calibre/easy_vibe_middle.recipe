class Blog(BasicNewsRecipe):  # 继承 BasicNewsRecipe 类的新类名

    # ///////////////////
    # 设置电子书元数据
    # ///////////////////
    title = "easy_vibe_middle"  # 电子书名
    description = u"easy vibe中级开发"  # 电子书简介
